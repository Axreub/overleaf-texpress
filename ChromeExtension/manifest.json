{
    "manifest_version": 3,
    "name": "TeXpress",
    "description": "An extension that allows you to write LaTeX math in Overleaf faster and easier using shortcuts.",
    "version": "1.0.0",
    "content_scripts": [
        {
            "matches": [
                "https://www.overleaf.com/project/*"
            ],
            "js": [
                "bundle.js"
            ],
            "run_at": "document_idle",
            "world": "MAIN"
        }
    ]
}